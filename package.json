{
  "name": "dotabod",
  "private": true,
  "scripts": {
    "cache:clean": "rm -rf node_modules pnpm-lock.yaml",
    "up": "pnpm update --interactive --latest",
    "nps": "doppler run -- bash services/mongodb/updatenps.sh",
    "exportnps": "doppler run -- bash services/mongodb/export.sh",
    "just": "doppler run -- bash runner.sh",
    "just-prod": "DOPPLER_CONFIG=prd doppler run -- bash runner.sh",
    "build:all": "pnpm -r run build",
    "typecheck:all": "pnpm -r run typecheck",
    "lint:all": "vp check",
    "lint:fix": "vp lint --fix && vp fmt",
    "knip": "knip",
    "test": "vp test",
    "test:all": "vp test"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "knip": "^6.14.2",
    "lefthook": "^1.11.6",
    "ts-morph": "^28.0.0",
    "typescript": "^5.8",
    "vite-plus": "0.1.23"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "pnpm@11.2.2"
}
