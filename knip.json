{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["packages/clip-processor-py/**"],
  "ignoreBinaries": ["doppler", "upgrade-interactive", "i18next"],
  "workspaces": {
    ".": {
      "entry": [
        "detect-circular-deps.ts",
        "scripts/remove-unused-decls.ts",
        "services/crowdin/src/i18next-parser.config.js",
        "services/mongodb/src/init.js"
      ]
    },
    "packages/dota": {
      "entry": ["src/dev/index.ts", "src/**/__tests__/**/*.ts", "src/**/*.test.ts"]
    },
    "packages/profanity-filter": {
      "entry": ["src/example-client.ts", "tests/**/*.ts"]
    },
    "packages/shared-utils": {},
    "packages/steam": {},
    "packages/twitch": {},
    "packages/twitch-chat": {
      "entry": ["src/**/__tests__/**/*.ts"]
    },
    "packages/twitch-events": {
      "entry": ["src/**/__tests__/**/*.ts"]
    }
  }
}
