{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "options": {
    "reportUnusedDisableDirectives": "error"
  },
  "rules": {
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_",
        "destructuredArrayIgnorePattern": "^_"
      }
    ]
  },
  "env": {
    "builtin": true
  },
  "overrides": [
    {
      "files": [
        "**/__tests__/**",
        "**/*.test.ts",
        "**/tests/**",
        "**/setupMocks.ts",
        "**/sharedMocks.ts"
      ],
      "rules": {
        "unicorn/no-thenable": "off"
      }
    }
  ]
}
