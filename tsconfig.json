{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "sourceMap": true,
    "strictNullChecks": true,
    "types": ["node"],
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "incremental": true
  },
  "ts-node": {
    "esm": true,
    "files": false,
    "transpileOnly": true,
    "typeCheck": false,
    "require": ["tsconfig-paths/register"],
    "ignore": ["(?:^|/)node_modules/"]
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "**/*.test.ts",
    "**/*.spec.ts",
    "packages/clip-processor-py",
    "services"
  ]
}
