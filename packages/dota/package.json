{
  "name": "@dotabod/dota",
  "version": "1.0.1",
  "private": true,
  "description": "By leveraging insights from the Dota 2 official API, Dotabod will know exactly when to hide sensitive streamer information or engage with your Twitch audience.",
  "license": "GPL-3.0-or-later",
  "author": "Geczy",
  "type": "module",
  "main": "src/index.ts",
  "exports": "./dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "docker:production": "node dist/index.js",
    "docker:development": "tsx watch src/index.ts",
    "prebuild": "rm -rf dist",
    "build": "vp pack src/index.ts -f esm -d dist --sourcemap",
    "fix-users": "doppler run -- tsx ./src/dev/index.ts",
    "test": "vp test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dotabod/profanity-filter": "workspace:*",
    "@dotabod/shared-utils": "workspace:*",
    "@twurple/api": "7.2.1",
    "@twurple/ebs-helper": "^7.2.1",
    "@twurple/eventsub-base": "^7.2.1",
    "axios": "1.7.9",
    "chokidar": "^4.0.3",
    "cors": "^2.8.5",
    "country-code-emoji": "^2.3.0",
    "deepl-node": "^1.19.1",
    "dotaconstants": "github:dotabod/dotaconstants",
    "express": "^4.21.2",
    "express-body-parser-error-handler": "^1.0.7",
    "franc": "^6.2.0",
    "i18next": "^24.2.0",
    "i18next-fs-backend": "^2.6.0",
    "lodash.isequal": "^4.5.0",
    "mongodb": "^6.12.0",
    "redis": "^4.7.0",
    "retry": "^0.13.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/express": "^5.0.0",
    "@types/lodash.isequal": "^4.5.8",
    "@types/retry": "^0.12.5"
  }
}
