{
  "name": "@dotabod/twitch-chat",
  "version": "1.0.0",
  "private": true,
  "description": "Forward twitch chat to dotabod.",
  "license": "GPL-3.0-or-later",
  "author": "Geczy",
  "type": "module",
  "main": "src/index.ts",
  "exports": "./dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "docker:production": "node dist/index.js",
    "docker:development": "tsx watch src/index.ts",
    "prebuild": "rm -rf dist",
    "build": "vp pack src/index.ts -f esm -d dist --sourcemap",
    "test": "vp test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "i18next": "^24.2.0",
    "i18next-fs-backend": "^2.6.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  }
}
