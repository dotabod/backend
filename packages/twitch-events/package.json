{
  "name": "@dotabod/twitch-events",
  "version": "1.0.0",
  "private": true,
  "description": "We forward twitch events to dotabod.",
  "license": "GPL-3.0-or-later",
  "author": "Geczy",
  "type": "module",
  "main": "src/index.ts",
  "exports": "./dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "docker:production": "node dist/index.js",
    "docker:development": "tsx watch src/index.ts",
    "prebuild": "rm -rf dist",
    "build": "vp pack src/index.ts -f esm -d dist --sourcemap",
    "subscription-health-check": "tsx src/scripts/runSubscriptionHealthCheck.ts",
    "test": "vp test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dotabod/shared-utils": "workspace:*",
    "@twurple/api": "7.2.1",
    "@twurple/auth": "7.2.1",
    "express": "^4.21.2",
    "express-body-parser-error-handler": "^1.0.7",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.19"
  }
}
