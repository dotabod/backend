{
  "name": "@dotabod/steam",
  "description": "Forward twitch chat to dotabod.",
  "version": "1.0.0",
  "license": "GPL-3.0-or-later",
  "author": "Geczy",
  "main": "src/index.ts",
  "exports": "./dist/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun dist/index.js",
    "dev": "bun --watch src/index.ts",
    "docker:production": "bun ./dist/index.js",
    "docker:development": "bun src/index.ts",
    "build": "bun build --target=bun --outfile=./dist/index.js --outdir=./dist --production --sourcemap=external --packages=external ./src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/long": "^5.0.0",
    "@types/retry": "^0.12.5",
    "@types/steam": "^0.0.32"
  },
  "dependencies": {
    "@dotabod/shared-utils": "workspace:*",
    "dota2": "https://github.com/dotabod/node-dota2",
    "mongodb": "^6.5.0",
    "retry": "^0.13.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "steam-errors": "^1.0.0",
    "winston": "^3.13.0"
  }
}
