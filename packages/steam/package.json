{
  "name": "@dotabod/steam",
  "version": "1.0.0",
  "private": true,
  "description": "Forward twitch chat to dotabod.",
  "license": "GPL-3.0-or-later",
  "author": "Geczy",
  "type": "module",
  "main": "src/index.ts",
  "exports": "./dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "docker:production": "node dist/index.js",
    "docker:development": "tsx watch src/index.ts",
    "prebuild": "rm -rf dist",
    "build": "vp pack src/index.ts -f esm -d dist --sourcemap",
    "typecheck": "tsc --noEmit",
    "test": "vp test"
  },
  "dependencies": {
    "@dotabod/shared-utils": "workspace:*",
    "dota2": "https://github.com/dotabod/node-dota2",
    "long": "^5.3.1",
    "mongodb": "^6.5.0",
    "retry": "^0.13.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "steam-errors": "^1.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/long": "^5.0.0",
    "@types/retry": "^0.12.5",
    "@types/steam": "^0.0.32"
  }
}
